---
import Layout from '../layouts/Layout.astro';

interface Props {
  title: string;
  description: string;
  icon: string;
  items: string[];
  svg?: string;
}

const { title, description, icon, items, svg } = Astro.props;
---

<Layout title={title} description={description}>

  <!-- Breadcrumb -->
  <nav class="max-w-7xl mx-auto px-5 md:px-10 pt-10 pb-2">
    <ol class="flex items-center gap-2 text-sm text-slate-400">
      <li><a href="/" class="hover:text-slate-700 transition-colors">Strona główna</a></li>
      <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></li>
      <li><a href="/instalacje" class="hover:text-slate-700 transition-colors">Instalacje</a></li>
      <li><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg></li>
      <li class="text-slate-700 font-medium">{title}</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="max-w-7xl mx-auto px-5 md:px-10 py-16 grid md:grid-cols-2 gap-12 md:gap-20 items-start">
    <div>
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-[#16a34a]/10 text-[#16a34a] mb-8">
        {svg
          ? <Fragment set:html={svg} />
          : <span class="text-3xl">{icon}</span>
        }
      </div>

      <h1 class="text-4xl md:text-5xl font-black tracking-tight leading-tight mb-6">
        {title}
      </h1>
      <p class="text-lg text-slate-500 leading-relaxed mb-10">
        {description}
      </p>

      <div class="flex flex-col sm:flex-row gap-3">
        <a href="/kontakt" class="inline-flex items-center justify-center gap-2 bg-[#f97316] hover:bg-[#ea580c] text-white font-bold px-8 py-4 rounded-xl transition-colors shadow-sm">
          Zapytaj o wycenę
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
        <a href="tel:+48509679175" class="inline-flex items-center justify-center gap-2 border border-slate-200 hover:border-[#16a34a] text-slate-700 hover:text-[#16a34a] font-semibold px-8 py-4 rounded-xl transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.64 4.9 2 2 0 0 1 3.62 2.69h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.06 6.06l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Zadzwoń
        </a>
      </div>
    </div>

    <!-- Scope list -->
    <div class="bg-slate-50 rounded-3xl p-8 border border-slate-100">
      <p class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-6">Zakres usług</p>
      <ul class="space-y-4">
        {items.map((item) => (
          <li class="flex items-start gap-3">
            <span class="flex items-center justify-center w-5 h-5 rounded-full bg-[#16a34a] text-white shrink-0 mt-0.5">
              <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </span>
            <span class="text-slate-700 leading-relaxed">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-slate-900 py-20 mt-8">
    <div class="max-w-3xl mx-auto px-5 text-center">
      <h2 class="text-3xl md:text-4xl font-black text-white mb-4">Masz pytania lub potrzebujesz wyceny?</h2>
      <p class="text-slate-400 mb-8 text-lg">Skontaktuj się z nami — bezpłatne doradztwo i szybka wycena.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/kontakt" class="inline-flex items-center justify-center bg-[#f97316] hover:bg-[#ea580c] text-white font-bold px-8 py-4 rounded-xl transition-colors">
          Wyślij zapytanie
        </a>
        <a href="tel:+48509679175" class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-white font-semibold px-8 py-4 rounded-xl transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.64 4.9 2 2 0 0 1 3.62 2.69h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.06 6.06l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          +48 509 679 175
        </a>
      </div>
    </div>
  </section>
</Layout>
