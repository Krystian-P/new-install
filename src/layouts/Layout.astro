---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'New Install – profesjonalne instalacje CO, wod-kan, gazowe i więcej na terenie całego regionu.' } = Astro.props;

const nav = [
  { label: 'Usługi', href: '/instalacje' },
  { label: 'Realizacje', href: '/realizacje' },
];
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="canonical" href={`https://newinstall.pl${Astro.url.pathname}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:site_name" content="New Install" />
    <meta property="og:title" content={`${title} | New Install`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://newinstall.pl${Astro.url.pathname}`} />

    <!-- JSON-LD LocalBusiness -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        "name": "New Install Wojciech Bezpalko",
        "url": "https://newinstall.pl",
        "telephone": "+48509679175",
        "email": "hydraulikpl@wp.pl",
        "description": "Profesjonalne instalacje CO, wodno-kanalizacyjne, gazowe, kotłownie, pompy ciepła, przyłącza, przeciski i wentylacja. Puławy i okolice.",
        "priceRange": "$$",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "ul. Szubartowskiego 20",
          "addressLocality": "Puławy",
          "postalCode": "24-100",
          "addressRegion": "lubelskie",
          "addressCountry": "PL"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 51.40851,
          "longitude": 22.00743
        },
        "areaServed": [
          { "@type": "City", "name": "Puławy" },
          { "@type": "AdministrativeArea", "name": "powiat puławski" },
          { "@type": "AdministrativeArea", "name": "województwo lubelskie" }
        ],
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Usługi instalacyjne",
          "itemListElement": [
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Instalacje Centralnego Ogrzewania" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Instalacje Wodno-Kanalizacyjne" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Instalacje Gazowe" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Kotłownie i Pompy Ciepła" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Przyłącza Wody i Kanalizacji" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Przeciski i Usługi Kopiarkami" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Szamba i Oczyszczalnie Ścieków" } },
            { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Wentylacja i Rekuperacja" } }
          ]
        }
      }
    </script>

    <title>{title} | New Install</title>
  </head>
  <body class="bg-white text-slate-800 antialiased" style="font-family: 'Inter', system-ui, sans-serif;">

    <!-- NAV -->
    <header id="site-header" class="fixed top-0 inset-x-0 z-50 transition-all duration-300 bg-white/95 backdrop-blur-sm border-b border-transparent" id="header">
      <div class="max-w-7xl mx-auto px-5 md:px-10 h-16 flex items-center justify-between gap-8">

        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 shrink-0">
          <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-[#16a34a]">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            </svg>
          </span>
          <span class="text-lg font-bold tracking-tight text-slate-900">
            new<span class="text-[#f97316]">install</span>
          </span>
        </a>

        <!-- Desktop nav -->
        <nav class="hidden md:flex items-center gap-1">
          {nav.map(n => (
            <a href={n.href} class="px-4 py-2 text-sm font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-100 rounded-lg transition-colors">
              {n.label}
            </a>
          ))}
        </nav>

        <!-- CTA -->
        <div class="hidden md:flex items-center gap-3">
          <a href="tel:+48509679175" class="flex items-center gap-2 text-sm font-semibold text-slate-700 hover:text-[#16a34a] transition-colors">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.64 4.9 2 2 0 0 1 3.62 2.69h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.06 6.06l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            +48 509 679 175
          </a>
          <a href="/kontakt" class="bg-[#f97316] hover:bg-[#ea580c] text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors shadow-sm">
            Darmowa wycena
          </a>
        </div>

        <!-- Mobile toggle -->
        <button id="menu-toggle" class="md:hidden p-2 rounded-lg hover:bg-slate-100 transition-colors" aria-label="Menu">
          <svg id="menu-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-slate-100 bg-white">
        <div class="max-w-7xl mx-auto px-5 py-4 flex flex-col gap-1">
          {nav.map(n => (
            <a href={n.href} class="px-4 py-3 text-sm font-medium text-slate-700 hover:text-slate-900 hover:bg-slate-50 rounded-lg transition-colors">
              {n.label}
            </a>
          ))}
          <div class="pt-2 mt-1 border-t border-slate-100 flex flex-col gap-2">
            <a href="tel:+48509679175" class="flex items-center gap-2 px-4 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-50 rounded-lg">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.64 4.9 2 2 0 0 1 3.62 2.69h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.06 6.06l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              +48 509 679 175
            </a>
            <a href="/kontakt" class="bg-[#f97316] text-white text-sm font-semibold px-4 py-3 rounded-lg text-center">
              Darmowa wycena
            </a>
          </div>
        </div>
      </div>
    </header>

    <main class="pt-16">
      <slot />
    </main>

    <!-- FOOTER -->
    <footer class="bg-slate-900 text-slate-400 mt-24">
      <div class="max-w-7xl mx-auto px-5 md:px-10 pt-16 pb-10">
        <div class="grid md:grid-cols-4 gap-10 mb-12">

          <!-- Brand -->
          <div class="md:col-span-1">
            <a href="/" class="flex items-center gap-2 mb-4">
              <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-[#16a34a]">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
                </svg>
              </span>
              <span class="text-lg font-bold text-white tracking-tight">
                new<span class="text-[#f97316]">install</span>
              </span>
            </a>
            <p class="text-sm leading-relaxed">
              Profesjonalne usługi instalacyjne dla klientów indywidualnych i firm. Gwarancja jakości i terminowości.
            </p>
          </div>

          <!-- Services -->
          <div>
            <p class="text-white font-semibold text-sm mb-4">Usługi</p>
            <ul class="space-y-2.5 text-sm">
              <li><a href="/instalacje/co" class="hover:text-white transition-colors">Centralne Ogrzewanie</a></li>
              <li><a href="/instalacje/wod-kan" class="hover:text-white transition-colors">Instalacje Wod-Kan</a></li>
              <li><a href="/instalacje/gazowe" class="hover:text-white transition-colors">Instalacje Gazowe</a></li>
              <li><a href="/instalacje/kotlownie" class="hover:text-white transition-colors">Kotłownie & Pompy Ciepła</a></li>
            </ul>
          </div>
          <div>
            <p class="text-white font-semibold text-sm mb-4 md:invisible">_</p>
            <ul class="space-y-2.5 text-sm">
              <li><a href="/instalacje/przylacza" class="hover:text-white transition-colors">Przyłącza</a></li>
              <li><a href="/instalacje/przeciski" class="hover:text-white transition-colors">Przeciski & Kopiarki</a></li>
              <li><a href="/instalacje/szamba" class="hover:text-white transition-colors">Szamba & Oczyszczalnie</a></li>
              <li><a href="/instalacje/wentylacja" class="hover:text-white transition-colors">Wentylacja</a></li>
            </ul>
          </div>

          <!-- Contact -->
          <div>
            <p class="text-white font-semibold text-sm mb-4">Kontakt</p>
            <ul class="space-y-3 text-sm">
              <li>
                <a href="tel:+48509679175" class="flex items-center gap-2 hover:text-white transition-colors group">
                  <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-slate-800 group-hover:bg-[#16a34a] transition-colors">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.64 4.9 2 2 0 0 1 3.62 2.69h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.06 6.06l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                    </svg>
                  </span>
                  +48 509 679 175
                </a>
              </li>
              <li>
                <a href="mailto:hydraulikpl@wp.pl" class="flex items-center gap-2 hover:text-white transition-colors group">
                  <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-slate-800 group-hover:bg-[#16a34a] transition-colors">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                    </svg>
                  </span>
                  hydraulikpl@wp.pl
                </a>
              </li>
              <li class="flex items-center gap-2 text-slate-400">
                <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-slate-800 shrink-0">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                </span>
                ul. Szubartowskiego 20<br/>24-100 Puławy
              </li>
            </ul>
          </div>
        </div>

        <div class="border-t border-slate-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-slate-500">
          <p>© {new Date().getFullYear()} New Install Wojciech Bezpalko. Wszelkie prawa zastrzeżone.</p>
          <p>new-install.pl</p>
        </div>
      </div>
    </footer>

    <script>
      // Mobile menu toggle
      const toggle = document.getElementById('menu-toggle');
      const menu = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));

      // Header scroll shadow
      const header = document.getElementById('site-header');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 10) {
          header?.classList.add('border-slate-200', 'shadow-sm');
          header?.classList.remove('border-transparent');
        } else {
          header?.classList.remove('border-slate-200', 'shadow-sm');
          header?.classList.add('border-transparent');
        }
      });
    </script>
  </body>
</html>
