---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kontakt" description="Skontaktuj się z New Install – bezpłatna wycena, doradztwo techniczne, zapytania ofertowe.">

  <div class="max-w-7xl mx-auto px-5 md:px-10 py-16">

    <!-- Header -->
    <div class="max-w-2xl mb-16">
      <p class="text-[#16a34a] text-sm font-bold uppercase tracking-widest mb-3">Kontakt</p>
      <h1 class="text-4xl md:text-5xl font-black tracking-tight leading-tight mb-5">
        Porozmawiajmy<br/>o Twoim projekcie
      </h1>
      <p class="text-slate-500 text-lg leading-relaxed">
        Zadzwoń lub wypełnij formularz — odpowiemy w ciągu 24 godzin. Bezpłatna wycena i doradztwo techniczne.
      </p>
    </div>

    <div class="grid lg:grid-cols-5 gap-10 items-start">

      <!-- Contact cards -->
      <div class="lg:col-span-2 flex flex-col gap-4">

        <a href="tel:+48509679175" class="group flex items-center gap-5 bg-white border border-slate-200 hover:border-[#16a34a] hover:shadow-lg hover:shadow-green-100/50 rounded-2xl p-6 transition-all">
          <span class="flex items-center justify-center w-14 h-14 rounded-xl bg-[#16a34a]/10 text-[#16a34a] group-hover:bg-[#16a34a] group-hover:text-white transition-colors shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5 19.79 19.79 0 0 1 1.64 4.9 2 2 0 0 1 3.62 2.69h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.06 6.06l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </span>
          <div>
            <p class="text-xs text-slate-400 font-semibold uppercase tracking-wide mb-0.5">Telefon</p>
            <p class="text-xl font-bold text-slate-900 group-hover:text-[#16a34a] transition-colors">+48 509 679 175</p>
            <p class="text-sm text-slate-400 mt-0.5">Pon–Pt 7:00–18:00</p>
          </div>
        </a>

        <a href="mailto:hydraulikpl@wp.pl" class="group flex items-center gap-5 bg-white border border-slate-200 hover:border-[#16a34a] hover:shadow-lg hover:shadow-green-100/50 rounded-2xl p-6 transition-all">
          <span class="flex items-center justify-center w-14 h-14 rounded-xl bg-[#f97316]/10 text-[#f97316] group-hover:bg-[#f97316] group-hover:text-white transition-colors shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </span>
          <div>
            <p class="text-xs text-slate-400 font-semibold uppercase tracking-wide mb-0.5">Email</p>
            <p class="text-xl font-bold text-slate-900 group-hover:text-[#16a34a] transition-colors">hydraulikpl@wp.pl</p>
            <p class="text-sm text-slate-400 mt-0.5">Odpowiadamy w 24h</p>
          </div>
        </a>

        <div class="flex items-center gap-5 bg-slate-50 border border-slate-100 rounded-2xl p-6">
          <span class="flex items-center justify-center w-14 h-14 rounded-xl bg-slate-200 text-slate-500 shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </span>
          <div>
            <p class="text-xs text-slate-400 font-semibold uppercase tracking-wide mb-0.5">Adres</p>
            <p class="text-lg font-bold text-slate-900">ul. Szubartowskiego 20</p>
            <p class="text-sm text-slate-400 mt-0.5">24-100 Puławy</p>
          </div>
        </div>

        <div class="flex items-center gap-5 bg-slate-50 border border-slate-100 rounded-2xl p-6">
          <span class="flex items-center justify-center w-14 h-14 rounded-xl bg-slate-200 text-slate-500 shrink-0">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><line x1="2" y1="12" x2="22" y2="12"/>
            </svg>
          </span>
          <div>
            <p class="text-xs text-slate-400 font-semibold uppercase tracking-wide mb-0.5">Obszar działania</p>
            <p class="text-lg font-bold text-slate-900">Puławy i okolice</p>
            <p class="text-sm text-slate-400 mt-0.5">Powiat puławski, woj. lubelskie</p>
          </div>
        </div>

      </div>

      <!-- Form -->
      <div class="lg:col-span-3 bg-white border border-slate-200 rounded-3xl p-8 md:p-10 shadow-sm">
        <h2 class="text-2xl font-black mb-8 text-slate-900">Wyślij zapytanie</h2>

        <form name="kontakt" method="POST" class="space-y-5">
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-semibold text-slate-700 mb-2">Imię i nazwisko *</label>
              <input
                type="text" id="name" name="name" required
                placeholder="Jan Kowalski"
                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#16a34a]/30 focus:border-[#16a34a] transition-colors placeholder:text-slate-400"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-slate-700 mb-2">Telefon</label>
              <input
                type="tel" id="phone" name="phone"
                placeholder="+48 509 679 175"
                class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#16a34a]/30 focus:border-[#16a34a] transition-colors placeholder:text-slate-400"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-slate-700 mb-2">Email *</label>
            <input
              type="email" id="email" name="email" required
              placeholder="jan@example.com"
              class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#16a34a]/30 focus:border-[#16a34a] transition-colors placeholder:text-slate-400"
            />
          </div>

          <div>
            <label for="service" class="block text-sm font-semibold text-slate-700 mb-2">Rodzaj usługi</label>
            <select
              id="service" name="service"
              class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#16a34a]/30 focus:border-[#16a34a] transition-colors text-slate-700 appearance-none"
            >
              <option value="">— Wybierz usługę —</option>
              <option>Centralne Ogrzewanie</option>
              <option>Instalacje Wod-Kan</option>
              <option>Instalacje Gazowe</option>
              <option>Kotłownie &amp; Pompy Ciepła</option>
              <option>Przyłącza Wody i Kanalizacji</option>
              <option>Przeciski &amp; Usługi Kopiarkami</option>
              <option>Szamba &amp; Oczyszczalnie</option>
              <option>Wentylacja &amp; Rekuperacja</option>
              <option>Inne</option>
            </select>
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-slate-700 mb-2">Wiadomość *</label>
            <textarea
              id="message" name="message" rows={5} required
              placeholder="Opisz zakres prac, lokalizację i termin realizacji..."
              class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#16a34a]/30 focus:border-[#16a34a] transition-colors resize-none placeholder:text-slate-400"
            ></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-[#f97316] hover:bg-[#ea580c] text-white font-bold py-4 rounded-xl transition-colors text-base shadow-sm shadow-orange-200 flex items-center justify-center gap-2"
          >
            Wyślij zapytanie
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </button>

          <p class="text-xs text-slate-400 text-center">
            Twoje dane są bezpieczne. Odpowiadamy w ciągu 24 godzin.
          </p>
        </form>
      </div>
    </div>
  </div>
</Layout>
