---
import Layout from '../layouts/Layout.astro';

const categories = ['Wszystkie', 'Kotłownie', 'Centralne Ogrzewanie', 'Wod-Kan', 'Przyłącza', 'Przeciski'];

const projects = [
  { title: 'Kotłownia gazowa kondensacyjna', category: 'Kotłownie', location: 'Dom jednorodzinny', year: '2024' },
  { title: 'Instalacja CO z ogrzewaniem podłogowym', category: 'Centralne Ogrzewanie', location: 'Budynek mieszkalny', year: '2024' },
  { title: 'Przyłącze wod-kan', category: 'Przyłącza', location: 'Nowy budynek', year: '2023' },
  { title: 'Przecisk pod drogą powiatową 80m', category: 'Przeciski', location: 'Droga gminna', year: '2023' },
  { title: 'Modernizacja instalacji CO', category: 'Centralne Ogrzewanie', location: 'Blok mieszkalny', year: '2023' },
  { title: 'Pompa ciepła powietrze-woda', category: 'Kotłownie', location: 'Dom pasywny', year: '2024' },
  { title: 'Wymiana pionów wod-kan', category: 'Wod-Kan', location: 'Budynek wielorodzinny', year: '2022' },
  { title: 'Instalacja rekuperacji', category: 'Wentylacja', location: 'Dom jednorodzinny', year: '2024' },
  { title: 'Przyłącze wodociągowe 120m', category: 'Przyłącza', location: 'Osiedle mieszkaniowe', year: '2023' },
];
---

<Layout title="Realizacje" description="Galeria zrealizowanych projektów – instalacje CO, wod-kan, kotłownie, przyłącza i więcej.">

  <!-- Header -->
  <section class="max-w-7xl mx-auto px-5 md:px-10 pt-16 pb-4">
    <p class="text-[#16a34a] text-sm font-bold uppercase tracking-widest mb-3">Portfolio</p>
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
      <h1 class="text-4xl md:text-5xl font-black tracking-tight leading-tight">Nasze realizacje</h1>
      <p class="text-slate-500 max-w-md">Każdy projekt to indywidualne podejście, najwyższa jakość wykonania i gwarancja na każdą realizację.</p>
    </div>
  </section>

  <!-- Filter pills -->
  <div class="max-w-7xl mx-auto px-5 md:px-10 mt-10 mb-4 flex flex-wrap gap-2">
    {categories.map((cat, i) => (
      <button class={`px-4 py-2 rounded-full text-sm font-semibold border transition-colors ${i === 0 ? 'bg-slate-900 text-white border-slate-900' : 'bg-white text-slate-600 border-slate-200 hover:border-slate-400'}`}>
        {cat}
      </button>
    ))}
  </div>

  <!-- Grid -->
  <div class="max-w-7xl mx-auto px-5 md:px-10 py-8">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map((p) => (
        <div class="group rounded-2xl overflow-hidden border border-slate-200 hover:border-[#16a34a] hover:shadow-xl hover:shadow-green-100/50 transition-all duration-200 bg-white">
          <!-- Photo placeholder -->
          <div class="relative bg-slate-100 h-52 overflow-hidden flex items-center justify-center">
            <div class="absolute inset-0 bg-gradient-to-br from-slate-200 to-slate-100"></div>
            <svg class="relative z-10 text-slate-300 w-12 h-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
            </svg>
            <!-- Category badge -->
            <span class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm text-slate-700 text-xs font-semibold px-3 py-1.5 rounded-full">
              {p.category}
            </span>
          </div>
          <div class="p-5">
            <h3 class="font-bold text-slate-900 text-base mb-2 group-hover:text-[#16a34a] transition-colors">{p.title}</h3>
            <div class="flex items-center gap-3 text-xs text-slate-400">
              <span class="flex items-center gap-1">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                {p.location}
              </span>
              <span>·</span>
              <span>{p.year}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- CTA -->
  <section class="max-w-7xl mx-auto px-5 md:px-10 py-16">
    <div class="bg-slate-900 rounded-3xl p-12 text-center relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 28px 28px;"></div>
      <div class="absolute bottom-0 right-0 w-72 h-72 bg-[#f97316]/20 rounded-full blur-3xl pointer-events-none"></div>
      <div class="relative z-10">
        <h2 class="text-3xl md:text-4xl font-black text-white mb-4">Masz podobny projekt?</h2>
        <p class="text-slate-400 text-lg mb-8">Chętnie omówimy szczegóły i przygotujemy bezpłatną wycenę.</p>
        <a href="/kontakt" class="inline-flex items-center gap-2 bg-[#f97316] hover:bg-[#ea580c] text-white font-bold px-10 py-4 rounded-xl transition-colors shadow-lg shadow-orange-900/30">
          Skontaktuj się
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

</Layout>
