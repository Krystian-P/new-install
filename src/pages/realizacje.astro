    image: '/pics/WhatsApp Image 2026-04-06 at 19.18.36 (11).jpeg',
  },
  {
    title: 'Montaż studni rewizyjnej PVC',
    category: 'Przyłącza',
    location: 'Posesja prywatna',
    year: '2025',
    image: '/pics/WhatsApp Image 2026-04-06 at 19.59.27 (25).jpeg',
